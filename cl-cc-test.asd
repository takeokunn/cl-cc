     (:file "vm-dispatch-tests")
     (:file "vm-dispatch-gf-tests")
     (:file "vm-dispatch-gf-multi-tests")
     (:file "vm-bridge-tests")
     (:file "vm-opcodes-tests")
     (:file "vm-opcodes-defs-tests")
     (:file "vm-tests")
     (:file "package-tests")
