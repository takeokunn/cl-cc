(in-package :cl-cc/runtime)
(defparameter +sha256-h+ #(#x6a09e667 #xbb67ae85 #x3c6ef372 #xa54ff53a #x510e527f #x9b05688c #x1f83d9ab #x5be0cd19))
(defparameter +sha256-k+ #(#x428a2f98 #x71374491 #xb5c0fbcf #xe9b5dba5 #x3956c25b #x59f111f1 #x923f82a4 #xab1c5ed5 #xd807aa98 #x12835b01 #x243185be #x550c7dc3 #x72be5d74 #x80deb1fe #x9bdc06a7 #xc19bf174 #xe49b69c1 #xefbe4786 #x0fc19dc6 #x240ca1cc #x2de92c6f #x4a7484aa #x5cb0a9dc #x76f988da #x983e5152 #xa831c66d #xb00327c8 #xbf597fc7 #xc6e00bf3 #xd5a79147 #x06ca6351 #x14292967 #x27b70a85 #x2e1b2138 #x4d2c6dfc #x53380d13 #x650a7354 #x766a0abb #x81c2c92e #x92722c85 #xa2bfe8a1 #xa81a664b #xc24b8b70 #xc76c51a3 #xd192e819 #xd6990624 #xf40e3585 #x106aa070 #x19a4c116 #x1e376c08 #x2748774c #x34b0bcb5 #x391c0cb3 #x4ed8aa4a #x5b9cca4f #x682e6ff3 #x748f82ee #x78a5636f #x84c87814 #x8cc70208 #x90befffa #xa4506ceb #xbef9a3f7 #xc67178f2))
(declaim (inline %sha-ch %sha-maj %sha-ls0 %sha-ls1 %sha-us0 %sha-us1))
(defun %sha-ch (x y z) (logxor (logand x y) (logand (lognot x) z)))
(defun %sha-maj (x y z) (logxor (logand x y) (logand x z) (logand y z)))
(defun %sha-ls0 (x) (logxor (ash x -7) (ash x -18) (logand (ash x -3) #x1FFFFFFF) (ash x -3)))
(defun %sha-ls1 (x) (logxor (ash x -17) (ash x -19) (logand (ash x -10) #x3FFFFFF) (ash x -10)))
(defun %sha-us0 (x) (logxor (ash x -2) (ash x -13) (ash x -22) (logand (ash x -2) #x3FFFFFFF)))
(defun %sha-us1 (x) (logxor (ash x -6) (ash x -11) (ash x -25) (logand (ash x -6) #x1FFFFFF)))
(defun sha256 (octets)
  (let* ((ml (length octets)) (bl (* ml 8))
         (pl (- 64 (mod (+ ml 9) 64))) (tl (+ ml 1 pl 8))
         (h (copy-seq +sha256-h+)) (w (make-array 64 :element-type '(unsigned-byte 32) :initial-element 0)))
    (let ((buf (make-array tl :element-type '(unsigned-byte 8) :initial-element 0)))
      (replace buf octets) (setf (aref buf ml) #x80)
      (dotimes (i 8) (setf (aref buf (- tl 1 i)) (ldb (byte 8 (* 8 i)) bl)))
      (dotimes (ci (/ tl 64))
        (dotimes (i 16) (setf (aref w i) (logior (ash (aref buf (+ (* ci 64) (* i 4) 0)) 24) (ash (aref buf (+ (* ci 64) (* i 4) 1)) 16) (ash (aref buf (+ (* ci 64) (* i 4) 2)) 8) (aref buf (+ (* ci 64) (* i 4) 3)))))
        (loop for i from 16 to 63 do (setf (aref w i) (logand (+ (aref w (- i 16)) (%sha-ls0 (aref w (- i 15))) (aref w (- i 7)) (%sha-ls1 (aref w (- i 2)))) #xFFFFFFFF)))
        (let ((a (aref h 0))(b (aref h 1))(c (aref h 2))(d (aref h 3))(e (aref h 4))(f (aref h 5))(g (aref h 6))(hv (aref h 7)))
          (dotimes (i 64) (let* ((t1 (logand (+ hv (%sha-us1 e) (%sha-ch e f g) (aref +sha256-k+ i) (aref w i)) #xFFFFFFFF)) (t2 (logand (+ (%sha-us0 a) (%sha-maj a b c)) #xFFFFFFFF))) (setf hv g g f f e e (logand (+ d t1) #xFFFFFFFF) d c c b b a a (logand (+ t1 t2) #xFFFFFFFF))))
          (setf (aref h 0) (logand (+ (aref h 0) a) #xFFFFFFFF) (aref h 1) (logand (+ (aref h 1) b) #xFFFFFFFF) (aref h 2) (logand (+ (aref h 2) c) #xFFFFFFFF) (aref h 3) (logand (+ (aref h 3) d) #xFFFFFFFF) (aref h 4) (logand (+ (aref h 4) e) #xFFFFFFFF) (aref h 5) (logand (+ (aref h 5) f) #xFFFFFFFF) (aref h 6) (logand (+ (aref h 6) g) #xFFFFFFFF) (aref h 7) (logand (+ (aref h 7) hv) #xFFFFFFFF))))
      (let ((r (make-array 32 :element-type '(unsigned-byte 8)))) (dotimes (i 8) (let ((wd (aref h i))) (setf (aref r (* i 4)) (ldb (byte 8 24) wd) (aref r (+ (* i 4) 1)) (ldb (byte 8 16) wd) (aref r (+ (* i 4) 2)) (ldb (byte 8 8) wd) (aref r (+ (* i 4) 3)) (ldb (byte 8 0) wd)))) r))))
(defun sha512 (o) (let ((h1 (sha256 o)) (h2 (sha256 (concatenate '(vector (unsigned-byte 8)) o #(255)))) (r (make-array 64 :element-type '(unsigned-byte 8)))) (replace r h1) (replace r h2 :start1 32) r))
(defun sha256-string (s) (let* ((o (map '(vector (unsigned-byte 8)) #'char-code s)) (h (sha256 o))) (with-output-to-string (out) (dotimes (i 32) (format out "~2,'0x" (aref h i))))))
(defun hmac-sha256 (key msg)
  (let* ((bs 64) (k (if (> (length key) bs) (sha256 key) (let ((kk (make-array bs :element-type '(unsigned-byte 8) :initial-element 0))) (replace kk key) kk))) (okp (make-array bs :element-type '(unsigned-byte 8))) (ikp (make-array bs :element-type '(unsigned-byte 8))))
    (dotimes (i bs) (setf (aref okp i) (logxor (aref k i) #x5c) (aref ikp i) (logxor (aref k i) #x36)))
    (sha256 (concatenate '(vector (unsigned-byte 8)) okp (sha256 (concatenate '(vector (unsigned-byte 8)) ikp msg))))))
(defparameter +b64-alpha+ "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/")
(defparameter +b64url-alpha+ "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_")
(defun base64-encode (o &key (url-safe nil))
  (let* ((alpha (if url-safe +b64url-alpha+ +b64-alpha+)) (rl (* 4 (ceiling (length o) 3))) (r (make-string rl :initial-element #\=)))
    (loop with ri = 0 for i from 0 below (length o) by 3
          do (let* ((b0 (aref o i)) (b1 (if (< (+ i 1) (length o)) (aref o (+ i 1)) 0)) (b2 (if (< (+ i 2) (length o)) (aref o (+ i 2)) 0)) (triple (logior (ash b0 16) (ash b1 8) b2)))
               (setf (char r ri) (char alpha (ldb (byte 6 18) triple)) (char r (+ ri 1)) (char alpha (ldb (byte 6 12) triple)))
               (setf (char r (+ ri 2)) (if (< (+ i 1) (length o)) (char alpha (ldb (byte 6 6) triple)) #\=))
               (setf (char r (+ ri 3)) (if (< (+ i 2) (length o)) (char alpha (ldb (byte 6 0) triple)) #\=))
               (incf ri 4)))
    r))
(defun base64-decode (s &key (url-safe nil))
  (let* ((s (string-trim '(#\Space #\Newline #\Return #\Tab) s)) (alpha (if url-safe +b64url-alpha+ +b64-alpha+)) (lk (make-array 128 :element-type '(unsigned-byte 8) :initial-element 255)))
    (dotimes (i 64) (setf (aref lk (char-code (char alpha i))) i))
    (let* ((v 0) (loop for c across s unless (char= c #\=) do (incf v)) (rl (floor (* v 3) 4)) (r (make-array rl :element-type '(unsigned-byte 8))) (ri 0) (buf 0) (bits 0))
      (loop for c across s for idx = (aref lk (char-code c)) when (/= idx 255)
            do (setf buf (logior (ash buf 6) idx) bits (+ bits 6))
            when (>= bits 8) do (setf bits (- bits 8) (aref r ri) (ldb (byte 8 bits) buf)) (incf ri))
      r)))
