;;;; CSP Channels (FR-282)
(in-package :cl-cc/runtime)
(defstruct rt-channel (buffer nil) (capacity 0) (closed-p nil) (mutex (rt-make-mutex)) (send-cond (rt-make-condition-variable)) (recv-cond (rt-make-condition-variable)))
(defun rt-make-channel (&key (capacity 0)) (make-rt-channel :capacity capacity))
(defun rt-channel-send (ch val) (rt-with-mutex ((rt-channel-mutex ch)) (when (rt-channel-closed-p ch) (error "channel closed")) (loop while (>= (length (rt-channel-buffer ch)) (rt-channel-capacity ch)) do (rt-condition-wait (rt-channel-send-cond ch) (rt-channel-mutex ch))) (setf (rt-channel-buffer ch) (append (rt-channel-buffer ch) (list val))) (rt-condition-notify (rt-channel-recv-cond ch)) val))
(defun rt-channel-recv (ch) (rt-with-mutex ((rt-channel-mutex ch)) (loop until (or (rt-channel-closed-p ch) (rt-channel-buffer ch)) do (rt-condition-wait (rt-channel-recv-cond ch) (rt-channel-mutex ch))) (if (and (rt-channel-closed-p ch) (null (rt-channel-buffer ch))) nil (let ((val (car (rt-channel-buffer ch)))) (setf (rt-channel-buffer ch) (cdr (rt-channel-buffer ch))) (rt-condition-notify (rt-channel-send-cond ch)) val))))
(defun rt-channel-try-send (ch val) (rt-with-mutex ((rt-channel-mutex ch)) (when (and (not (rt-channel-closed-p ch)) (< (length (rt-channel-buffer ch)) (rt-channel-capacity ch))) (setf (rt-channel-buffer ch) (append (rt-channel-buffer ch) (list val))) (rt-condition-notify (rt-channel-recv-cond ch)) t)))
(defun rt-channel-try-recv (ch) (rt-with-mutex ((rt-channel-mutex ch)) (when (rt-channel-buffer ch) (let ((val (car (rt-channel-buffer ch)))) (setf (rt-channel-buffer ch) (cdr (rt-channel-buffer ch))) (rt-condition-notify (rt-channel-send-cond ch)) (values val t)))))
(defun rt-channel-close (ch) (rt-with-mutex ((rt-channel-mutex ch)) (setf (rt-channel-closed-p ch) t) (rt-condition-notify-all (rt-channel-recv-cond ch)) t))
(defun rt-channel-select (channels) (loop (dolist (ch channels) (multiple-value-bind (val ok) (rt-channel-try-recv ch) (when ok (return-from rt-channel-select (values val ch))))) (sleep 0.001)))
